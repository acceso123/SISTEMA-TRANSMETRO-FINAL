@{
    ViewData["Title"] = "Asignar Unidad";
}

<div class="container mt-5">
    <h2 class="text-success border-bottom pb-2 fw-bold">ASIGNACIÓN DE PILOTOS A FLOTA</h2>
    <p class="text-muted">Módulo de Despacho Centralizado - Validación Estricta</p>

    <div class="card shadow-sm mt-4" style="max-width: 600px;">
        <div class="card-body">
            <form asp-action="GuardarAsignacion" method="post">
                
                <div class="mb-4">
                    <label class="form-label fw-bold">1. Seleccionar Unidad (Buses Libres en Predio)</label>
                    <select class="form-select border-success" name="busId" required>
                        <option value="">-- Seleccione una unidad activa --</option>
                        @if (ViewBag.BusesDisponibles != null)
                        {
                            foreach (string bus in ViewBag.BusesDisponibles)
                            {
                                <option value="@bus">Unidad Transmetro @bus</option>
                            }
                        }
                    </select>
                    @if (ViewBag.BusesDisponibles == null || ((List<string>)ViewBag.BusesDisponibles).Count == 0)
                    {
                        <div class="form-text text-danger fw-bold mt-2">
                            ⚠️ ALERTA OPERATIVA: Todas las unidades están actualmente en ruta.
                        </div>
                    }
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">2. Pilotos Disponibles</label>
                    <select class="form-select border-success" name="pilotoId" required>
                        <option value="">-- Seleccione un conductor --</option>
                        @if (ViewBag.PilotosDisponibles != null)
                        {
                            foreach (var piloto in ViewBag.PilotosDisponibles)
                            {
                                <option value="@piloto.Id">@piloto.Nombre (@piloto.Id)</option>
                            }
                        }
                    </select>
                </div>

                <button type="submit" class="btn btn-success w-100 fw-bold py-2">CONFIRMAR ASIGNACIÓN</button>
            </form>
        </div>
    </div>
</div>