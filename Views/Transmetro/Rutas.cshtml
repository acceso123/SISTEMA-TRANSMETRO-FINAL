@model IEnumerable<TRANSMETRO.Models.Bus>
@{ ViewData["Title"] = "RUTAS - GPS"; }

<div class="d-flex justify-content-between align-items-center mt-4 border-bottom pb-2">
      <h2 class="text-uppercase fw-bold text-primary">MONITOREO DE LÍNEAS EN TIEMPO REAL</h2>
    <span class="badge bg-danger pulse-animation" style="font-size:16px;">◉ EN VIVO</span>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between">
                <h5 class="mb-0">RED - TRANSMETRO</h5>
                <small>ACTUALIZACIÓN: <span id="reloj"></span></small>
            </div>
            <div class="card-body bg-light">
                <div class="table-responsive">
                    <table class="table table-hover align-middle table-fixed">
                        <thead class="table-secondary">
                            <tr>
                                <th style="width: 10%;">UNIDAD</th>
                                <th style="width: 18%;">LÍNEA / DESTINO</th>
                                <th style="width: 12%;">PILOTO</th>
                                <th style="width: 10%;">VELOCIDAD</th>
                                <th style="width: 15%;">PROGRESO</th>
                                <th style="width: 15%;">OCUPACIÓN</th>
                                <th style="width: 20%;">ESTADO</th>
                            </tr>
                        </thead>
                        <tbody id="tablaSimulada">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .pulse-animation { animation: pulse 1.5s infinite; }
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }
    .progress { height: 20px; background-color: #343a40; }
    .progress-bar { transition: width 1s ease-in-out; }
    .table-fixed { table-layout: fixed; width: 100%; }
    .badge-estado { display: inline-block; width: 100%; text-align: center; padding: 8px; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
</style>

<script>
    // PILOTOS 
    const nombres = ["Carlos", "Luis", "Ana", "Jorge", "María", "Pedro", "Sofía", "Miguel", "Lucía", "Diego"];
    const apellidos = ["García", "Pérez", "López", "Martínez", "Rodríguez", "Gómez", "Fernández", "Díaz", "Morales", "Ramírez"];
    function generarNombrePiloto() { return nombres[Math.floor(Math.random() * nombres.length)] + " " + apellidos[Math.floor(Math.random() * apellidos.length)]; }

    // BASE DE DATOS
    function obtenerDatosOficiales(linea) {
        const lineasOficiales = {
            "LÍNEA 1": { color: "#FFF", bg: "#4A235A", destino: "CENTRO CÍVICO - ZONA 1" },
            "LÍNEA 2": { color: "#FFF", bg: "#9B59B6", destino: "SAN SEBASTIÁN - ZONA 1" },
            "LÍNEA 6": { color: "#000", bg: "#F1C40F", destino: "PROYECTOS - ZONA 6" },
            "LÍNEA 7": { color: "#FFF", bg: "#7F8C8D", destino: "USAC PERIFÉRICO - ZONA 12" },
            "LÍNEA 12": { color: "#FFF", bg: "#D35400", destino: "CENTRA SUR - ZONA 12" },
            "LÍNEA 13": { color: "#FFF", bg: "#27AE60", destino: "PLAZA ARGENTINA - ZONA 13" },
            "LÍNEA 18": { color: "#FFF", bg: "#2980B9", destino: "ATLÁNTIDA - ZONA 18" },
            "RUTA 5": { color: "#FFF", bg: "#000080", destino: "PARQUE COLÓN - ZONA 1" }
        };
        
        return lineasOficiales[linea.toUpperCase()] || { color: "#000", bg: "#ECF0F1", destino: "RUTA EN ASIGNACIÓN" };
    }

    // DATOS DE C#
    const datosReales = @Html.Raw(Json.Serialize(Model));
    let buses = datosReales.map(b => {
        let nombreLinea = (b.lineaAsignada || "").toUpperCase(); 
        let datosOficiales = obtenerDatosOficiales(nombreLinea);
        return {
            id: b.idBus,
            linea: nombreLinea, 
            destino: datosOficiales.destino,
            colorBg: datosOficiales.bg,
            colorTxt: datosOficiales.color,
            piloto: generarNombrePiloto(),
            vel: 0,
            progreso: Math.floor(Math.random() * 100), 
            ocup: b.pasajerosActuales,
            max: b.capacidadMaxima
        };
    });

    // SIMULACIÓN
    function actualizarDashboard() {
        const tbody = document.getElementById('tablaSimulada');
        tbody.innerHTML = '';
        document.getElementById('reloj').innerText = new Date().toLocaleTimeString();

        buses.forEach(bus => {
            let porcentajeOcup = (bus.ocup / bus.max) * 100;
            let estaPenalizado = (porcentajeOcup < 25);

            let colorOcupacion = "bg-success";
            let estadoTexto = "<span class='badge bg-success badge-estado text-uppercase'>EN TRÁNSITO</span>";

            if (estaPenalizado) {
                bus.vel = 0; 
                bus.ocup += Math.floor(Math.random() * 3) + 1; 
                if (bus.ocup > bus.max) bus.ocup = bus.max;

                colorOcupacion = "bg-warning text-dark";
                estadoTexto = "<span class='badge bg-warning text-dark badge-estado text-uppercase'>REGLA 25% - ESPERA DE 5 MIN</span>";
            } else {
                bus.progreso += Math.floor(Math.random() * 5);
                if (bus.progreso > 100) bus.progreso = 0; 

                if (bus.progreso > 0 && bus.progreso < 100) { 
                    bus.vel = Math.floor(Math.random() * (55 - 25 + 1)) + 25; 
                } else { 
                    bus.vel = 0; 
                }

                bus.ocup += Math.floor(Math.random() * 7) - 3; 
                if (bus.ocup < 0) bus.ocup = 0;
                if (bus.ocup > bus.max) bus.ocup = bus.max;

                if (porcentajeOcup > 50) {
                    colorOcupacion = "bg-danger";
                }
            }
          
            let fila = `
                <tr>
                    <td><strong>${bus.id}</strong></td>
                    <td>
                        <span class="badge fw-bold" style="background-color: ${bus.colorBg}; color: ${bus.colorTxt}; font-size:13px; width: 100%; padding: 6px;">
                            ${bus.linea}
                        </span>
                        <div style="font-size: 11px; margin-top:4px;" class="text-muted text-center fw-bold">
                            ${bus.destino}
                        </div>
                    </td>
                    <td>${bus.piloto}</td>
                    <td><span class="badge bg-secondary" style="width:70px;">${bus.vel} km/h</span></td>
                    <td>
                        <div class="progress">
                            <div class="progress-bar bg-info progress-bar-striped progress-bar-animated" style="width: ${bus.progreso}%"></div>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="progress flex-grow-1 me-2" style="height: 18px;">
                                <div class="progress-bar ${colorOcupacion}" style="width: ${porcentajeOcup}%"></div>
                            </div>
                            <span class="fw-bold" style="min-width: 65px; text-align: right; font-size: 13px;">${bus.ocup} / ${bus.max}</span>
                        </div>
                    </td>
                    <td>${estadoTexto}</td>
                </tr>
            `;
            tbody.innerHTML += fila;
        });
    }

    setInterval(actualizarDashboard, 3000);
    actualizarDashboard();
</script>