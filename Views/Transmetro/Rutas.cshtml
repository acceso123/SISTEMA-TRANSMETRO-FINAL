@{
    ViewData["Title"] = "RUTAS - GPS";
}

<div class="d-flex justify-content-between align-items-center mt-4 border-bottom pb-2">
    <h2 class="text-uppercase fw-bold text-primary">MONITOREO DE LÍNEAS EN TIEMPO REAL</h2>
    <span class="badge bg-danger pulse-animation" style="font-size:16px;">◉ EN VIVO</span>
</div>

<div class="card shadow-sm border-0 mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between">
        <h5 class="mb-0 text-uppercase fw-bold">RED - TRANSMETRO</h5>
        <small>ACTUALIZACIÓN: <span id="relojRutas"></span></small>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="table-layout: fixed; width: 100%;">
                <thead class="table-secondary text-uppercase">
                    <tr style="text-align: center;">
                        <th style="width: 8%; text-align: center;">UNIDAD</th>
                        <th style="width: 16%; text-align: center;">LÍNEA / DESTINO</th>
                        <th style="width: 14%; text-align: center;">PILOTO</th>
                        <th style="width: 8%; text-align: center;">VELOCIDAD</th>
                        <th style="width: 12%; text-align: center;">PROGRESO</th>
                        <th style="width: 18%; text-align: center;">OCUPACIÓN</th>
                        <th style="width: 18%; text-align: center;">ESTADO</th>
                    </tr>
                </thead>
                <tbody id="tablaRutas">
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .pulse-animation { animation: pulse 1.5s infinite; }
    @@keyframes pulse { 0% { opacity: 1; } 50% { opacity: 0.4; } 100% { opacity: 1; } }
    .badge-estado { display: inline-block; width: 100%; text-align: center; font-size: 10px; padding: 4px 8px !important; white-space: nowrap; }

    .linea-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 4px;
        color: white;
        font-weight: bold;
        font-size: 11px;
        margin-bottom: 3px;
        text-align: center;
        width: 100%;
    }

    .destino-texto {
        font-size: 10px;
        color: #666;
        text-align: center;
        text-transform: uppercase;
        margin-top: 2px;
    }

    .velocidad-badge {
        background-color: #6c757d;
        color: white;
        padding: 4px 8px;
        border-radius: 3px;
        font-weight: bold;
        font-size: 11px;
        display: inline-block;
    }

    .table tbody td {
        padding: 8px 10px !important;
        vertical-align: middle;
    }

    .progress {
        min-height: 16px !important;
    }
</style>

<script>
    // BASE DE DATOS
    const pilotosAsignados = {
        @foreach (var p in Transmetro.Models.DataRepository.Pilotos.Where(p => p.BusAsignado != "Ninguno"))
        {
            @Html.Raw($"\"{p.BusAsignado}\": {{nombre: \"{p.Nombre.ToUpper()}\", id: \"{p.Id}\"}},")
        }
    };

    const datosBuses = @Html.Raw(Json.Serialize(Transmetro.Models.DataRepository.Buses)) || [];

    const coloresLinea = {
        "LÍNEA 1":  "#6B21A8",
        "LÍNEA 2":  "#A855F7",
        "LÍNEA 6":  "#FBBF24",
        "LÍNEA 7":  "#6C757D",
        "LÍNEA 12": "#EA580C",
        "LÍNEA 13": "#22C55E",
        "LÍNEA 18": "#0EA5E9",
        "RUTA 5":   "#1E40AF"
    };

    const destinosLinea = {
        "LÍNEA 1":  "CENTRO CÍVICO - ZONA 1",
        "LÍNEA 2":  "SAN SEBASTIÁN - ZONA 1",
        "LÍNEA 6":  "PROYECTOS - ZONA 6",
        "LÍNEA 7":  "USAC PERIFÉRICO - ZONA 12",
        "LÍNEA 12": "CENTRA SUR - ZONA 12",
        "LÍNEA 13": "PLAZA ARGENTINA - ZONA 13",
        "LÍNEA 18": "ATLÁNTIDA - ZONA 18",
        "RUTA 5":   "PARQUE COLÓN - ZONA 1"
    };

    // MAPEO - FILTRAR UNIDADES CON PILOTOS ASIGNADOS
    let unidades = datosBuses
        .filter(b => pilotosAsignados[b.idBus || b.IdBus])
        .map(b => {
            const busId = b.idBus || b.IdBus;
            return {
                id:        busId,
                piloto:    pilotosAsignados[busId].nombre,
                velocidad: 0,
                progreso:  Math.floor(Math.random() * 60),
                ocupacion: b.pasajerosActuales || b.PasajerosActuales || 0,
                capacidad: b.capacidadMaxima   || b.CapacidadMaxima   || 80,
                linea:     b.lineaAsignada     || b.LineaAsignada     || "SIN ASIGNAR"
            };
        });

    // SIMULACIÓN - FLUJO DE PASAJEROS EN RUTAS
    function actualizarRutas() {
        const tbody = document.getElementById('tablaRutas');
        tbody.innerHTML = '';
        document.getElementById('relojRutas').innerText = new Date().toLocaleTimeString();

        if (unidades.length === 0) {
            tbody.innerHTML = `<tr><td colspan="7" class="text-center text-muted py-4">No hay unidades asignadas a pilotos en este momento</td></tr>`;
            return;
        }

        unidades.forEach(unidad => {
            // OCUPACIÓN - Varía ±3 pasajeros
            const varOcup = Math.floor(Math.random() * 7) - 3;
            unidad.ocupacion = Math.max(0, Math.min(unidad.capacidad, unidad.ocupacion + varOcup));
            let porcentajeOcup = (unidad.ocupacion / unidad.capacidad) * 100;

            // REGLA 25%
            let penalizado = (porcentajeOcup < 25);

            if (penalizado) {
                // BUS DEMASIADO VACÍO - PENALIZACIÓN
                unidad.velocidad = 0;
                
                unidad.ocupacion = Math.min(unidad.capacidad, unidad.ocupacion + Math.floor(Math.random() * 3) + 1);
                porcentajeOcup = (unidad.ocupacion / unidad.capacidad) * 100;
            } else {
                // BUS EN MOVIMIENTO NORMAL
               
                unidad.progreso += Math.floor(Math.random() * 5) + 1;
                if (unidad.progreso >= 100) unidad.progreso = 0;

                if (unidad.progreso === 0 || unidad.progreso >= 100) {
                    unidad.velocidad = 0;
                } else {
                    unidad.velocidad = Math.floor(Math.random() * 31) + 25;
                }
            }

            // COLORES DE BARRA DE OCUPACIÓN
            let colorBarraOcup = "bg-warning";
            if (penalizado) {
                colorBarraOcup = "bg-warning";
            } else if (porcentajeOcup > 50) {
                colorBarraOcup = "bg-danger";
            } else {
                colorBarraOcup = "bg-warning";
            }

            // ESTADO DEL BUS
            let estadoHtml = "";
            if (penalizado) {
                estadoHtml = `<span class="badge bg-warning text-dark badge-estado pulse-animation">REGLA 25% - ESPERA</span>`;
            } else {
                estadoHtml = `<span class="badge bg-success badge-estado">EN TRÁNSITO</span>`;
            }

            const colorLinea = coloresLinea[unidad.linea] || "#6C757D";
            const destino    = destinosLinea[unidad.linea] || "";

            // DISEÑO DE LA FILA
            let fila = `
                <tr>
                    <td style="text-align: center; font-weight: bold; font-size: 13px;">${unidad.id}</td>
                    <td style="text-align: center;">
                        <span class="linea-badge" style="background-color: ${colorLinea};">${unidad.linea}</span>
                        <div class="destino-texto">${destino}</div>
                    </td>
                    <td style="text-align: center; font-weight: bold; font-size: 12px;">${unidad.piloto}</td>
                    <td style="text-align: center;">
                        <span class="velocidad-badge">${unidad.velocidad} km/h</span>
                    </td>
                    <td>
                        <div class="d-flex align-items-center" style="gap: 6px;">
                            <div class="progress flex-grow-1" style="height: 16px;">
                                <div class="progress-bar bg-info progress-bar-striped progress-bar-animated"
                                     style="width: ${unidad.progreso}%"></div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="d-flex align-items-center" style="gap: 6px;">
                            <div class="progress flex-grow-1" style="height: 16px;">
                                <div class="progress-bar ${colorBarraOcup} progress-bar-striped progress-bar-animated"
                                     style="width: ${porcentajeOcup.toFixed(1)}%"></div>
                            </div>
                            <span class="fw-bold" style="min-width: 50px; text-align: right; font-size: 12px;">${unidad.ocupacion} / ${unidad.capacidad}</span>
                        </div>
                    </td>
                    <td style="text-align: center;">${estadoHtml}</td>
                </tr>
            `;
            tbody.innerHTML += fila;
        });
    }

    // ACTUALIZACIÓN CADA 2 SEGUNDOS
    function iniciar() {
        if (unidades.length === 0) {
            document.getElementById('tablaRutas').innerHTML = `
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        No hay unidades asignadas a pilotos en este momento
                    </td>
                </tr>`;
            return;
        }
        actualizarRutas();
        setInterval(actualizarRutas, 2000);
    }

    iniciar();
</script>